# AI VOC & Benchmark Studio Pro
# cp .env.example .env 후 실제 토큰을 입력하세요. 실제 .env는 GitHub에 올리지 마세요.

LLM_ENGINE=hf_api
HF_TOKEN=hf_replace_me

# HF Router Chat Completions 모델. provider suffix를 붙이면 호환성 문제가 줄어듭니다.
HF_ROUTER_MODEL=google/gemma-4-26B-A4B-it:deepinfra
HF_MODEL_CANDIDATES=google/gemma-4-26B-A4B-it:deepinfra,google/gemma-4-26B-A4B-it:novita,Zyphra/ZAYA1-8B,Zyphra/ZAYA1-74B-preview,mistralai/Mistral-7B-Instruct-v0.3

HF_MAX_TOKENS=1800
HF_TEMPERATURE=0.2
HF_TIMEOUT_CONNECT=10
HF_TIMEOUT_READ=120
HF_MAX_RETRIES=3
PORT=8501
